# Django Settings
SECRET_KEY=your-secret-key-here
DEBUG=False

# Database (Render will provide this automatically)
DATABASE_URL=postgresql://user:password@host:port/database

# Gemini AI API Key (for questionnaire feature)
GEMINI_API_KEY=your-gemini-api-key-here

# CORS Origins (Update with your frontend URL)
FRONTEND_URL=https://your-frontend-url.com

# AWS S3 Configuration (for image uploads)
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_STORAGE_BUCKET_NAME=your-s3-bucket-name
AWS_S3_REGION_NAME=us-east-1

# Custom Face Recognition Configuration (Optional - uses defaults if not set)
# Optimized for CPU-only deployment (AWS EC2)
# Model: Facenet (128-dim, fastest on CPU), Facenet512, ArcFace, VGG-Face, OpenFace, Dlib
FACE_RECOGNITION_MODEL=Facenet
# Detector: mtcnn (fast on CPU), opencv (fastest), retinaface (accurate but slower)
FACE_DETECTOR_BACKEND=mtcnn
# Threshold: 70.0 (balanced), 60-70 (lenient), 80-90 (strict)
FACE_RECOGNITION_THRESHOLD=70.0
